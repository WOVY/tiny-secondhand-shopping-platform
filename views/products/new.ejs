<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>상품 등록</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/nav') %>
<h1>상품 등록</h1>
<% if (errors && errors.length) { %>
  <ul class="errors">
    <% errors.forEach(function (e) { %><li><%= e.msg %></li><% }) %>
  </ul>
<% } %>
<form method="POST" action="/products/new" enctype="multipart/form-data">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <label>제목 <input type="text" name="title" maxlength="100" value="<%= values.title || '' %>" required></label><br>
  <label>설명 <textarea name="description" maxlength="2000"><%= values.description || '' %></textarea></label><br>
  <label>가격(원) <input type="number" name="price" min="0" value="<%= values.price || '' %>" required></label><br>
  <label>사진(선택) <input type="file" name="image" accept="image/png,image/jpeg,image/webp"></label><br>
  <button type="submit">등록</button>
</form>
</body>
</html>
