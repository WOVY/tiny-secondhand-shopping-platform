<%- include('../partials/head', { title: '내 상품 관리' }) %>
<body>
<%- include('../partials/nav') %>
<div class="container">
  <h1>내 상품 관리</h1>
  <p><a class="btn btn-sm btn-outline-secondary" href="/products/new">새 상품 등록</a></p>
  <ul class="list-group">
    <% products.forEach(function (p) { %>
      <li class="list-group-item d-flex justify-content-between align-items-center">
        <span>
          <a href="/products/<%= p.id %>"><%= p.title %></a>
          - <%= p.price %>원 - [<%= p.status %>]
        </span>
        <a class="btn btn-sm btn-outline-secondary" href="/products/<%= p.id %>/edit">수정</a>
      </li>
    <% }) %>
    <% if (products.length === 0) { %><li class="list-group-item">등록한 상품이 없습니다.</li><% } %>
  </ul>
</div>
<%- include('../partials/foot') %>
