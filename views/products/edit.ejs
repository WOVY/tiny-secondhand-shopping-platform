<%- include('../partials/head', { title: '상품 수정' }) %>
<body>
<%- include('../partials/nav') %>
<div class="container" style="max-width: 640px;">
  <h1>상품 수정</h1>
  <% if (errors && errors.length) { %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% errors.forEach(function (e) { %><li><%= e.msg %></li><% }) %>
      </ul>
    </div>
  <% } %>
  <form method="POST" action="/products/<%= product.id %>/edit" enctype="multipart/form-data" class="mb-4">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="mb-3">
      <label class="form-label">제목</label>
      <input type="text" name="title" class="form-control" maxlength="100" value="<%= product.title %>" required>
    </div>
    <div class="mb-3">
      <label class="form-label">설명</label>
      <textarea name="description" class="form-control" maxlength="2000"><%= product.description %></textarea>
    </div>
    <div class="mb-3">
      <label class="form-label">가격(원)</label>
      <input type="number" name="price" class="form-control" min="0" value="<%= product.price %>" required>
    </div>
    <div class="mb-3">
      <label class="form-label">사진 교체(선택)</label>
      <input type="file" name="image" class="form-control" accept="image/png,image/jpeg,image/webp">
    </div>
    <button type="submit" class="btn btn-primary">저장</button>
  </form>

  <form method="POST" action="/products/<%= product.id %>/delete" data-confirm="삭제하시겠습니까?">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button type="submit" class="btn btn-danger">삭제</button>
  </form>
  <script src="/js/confirm-forms.js"></script>
</div>
<%- include('../partials/foot') %>
