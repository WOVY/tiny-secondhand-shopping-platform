<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title><%= otherUser.username %>님과의 대화</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body data-current-user-id="<%= currentUser.id %>" data-other-user-id="<%= otherUser.id %>">
<%- include('../partials/nav') %>
<h1><%= otherUser.username %>님과의 대화</h1>
<ul id="messages">
  <% messages.forEach(function (m) { %>
    <li><strong><%= m.sender_username %>:</strong> <%= m.content %></li>
  <% }) %>
</ul>
<form id="chat-form">
  <input type="text" id="chat-input" maxlength="1000" autocomplete="off" required>
  <button type="submit">전송</button>
</form>
<script src="/socket.io/socket.io.js"></script>
<script src="/js/chat-dm.js"></script>
</body>
</html>
