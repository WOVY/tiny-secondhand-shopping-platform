<%- include('partials/head', { title: '마이페이지' }) %>
<body>
<%- include('partials/nav') %>
<div class="container" style="max-width: 640px;">
  <h1>마이페이지</h1>

  <% if (errors && errors.length) { %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% errors.forEach(function (e) { %><li><%= e.msg %></li><% }) %>
      </ul>
    </div>
  <% } %>
  <% if (bioUpdated) { %><div class="alert alert-success">소개글이 수정되었습니다.</div><% } %>
  <% if (passwordUpdated) { %><div class="alert alert-success">비밀번호가 변경되었습니다.</div><% } %>

  <h2>소개글</h2>
  <form method="POST" action="/profile/bio" class="mb-4">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="mb-3">
      <textarea name="bio" class="form-control" maxlength="500"><%= currentUser.bio %></textarea>
    </div>
    <button type="submit" class="btn btn-primary">저장</button>
  </form>

  <h2>비밀번호 변경</h2>
  <form method="POST" action="/profile/password">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="mb-3">
      <label class="form-label">현재 비밀번호</label>
      <input type="password" name="currentPassword" class="form-control" required>
    </div>
    <div class="mb-3">
      <label class="form-label">새 비밀번호</label>
      <input type="password" name="newPassword" class="form-control" required>
    </div>
    <button type="submit" class="btn btn-primary">변경</button>
  </form>
</div>
<%- include('partials/foot') %>
