<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>마이페이지</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/nav') %>
<h1>마이페이지</h1>

<% if (errors && errors.length) { %>
  <ul class="errors">
    <% errors.forEach(function (e) { %><li><%= e.msg %></li><% }) %>
  </ul>
<% } %>
<% if (bioUpdated) { %><p class="success">소개글이 수정되었습니다.</p><% } %>
<% if (passwordUpdated) { %><p class="success">비밀번호가 변경되었습니다.</p><% } %>

<h2>소개글</h2>
<form method="POST" action="/profile/bio">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <textarea name="bio" maxlength="500"><%= currentUser.bio %></textarea><br>
  <button type="submit">저장</button>
</form>

<h2>비밀번호 변경</h2>
<form method="POST" action="/profile/password">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <label>현재 비밀번호 <input type="password" name="currentPassword" required></label><br>
  <label>새 비밀번호 <input type="password" name="newPassword" required></label><br>
  <button type="submit">변경</button>
</form>
</body>
</html>
