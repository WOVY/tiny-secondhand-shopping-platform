<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>상품 관리</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/nav') %>
<h1>상품 관리</h1>
<table border="1" cellpadding="4">
  <tr><th>ID</th><th>제목</th><th>판매자</th><th>가격</th><th>상태</th><th>액션</th></tr>
  <% products.forEach(function (p) { %>
    <tr>
      <td><%= p.id %></td>
      <td><a href="/products/<%= p.id %>"><%= p.title %></a></td>
      <td><%= p.seller_username %></td>
      <td><%= p.price %></td>
      <td><%= p.status %></td>
      <td>
        <form action="/admin/products/<%= p.id %>/status" method="POST" style="display:inline">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit"><%= p.status === 'blocked' ? '차단 해제' : '차단' %></button>
        </form>
        <form action="/admin/products/<%= p.id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('삭제하시겠습니까?');">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit">삭제</button>
        </form>
      </td>
    </tr>
  <% }) %>
</table>
</body>
</html>
