<%- include('../partials/head', { title: '상품 관리' }) %>
<body>
<%- include('../partials/nav') %>
<div class="container">
  <h1>상품 관리</h1>
  <div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
      <thead>
        <tr><th>ID</th><th>제목</th><th>판매자</th><th>가격</th><th>상태</th><th>액션</th></tr>
      </thead>
      <tbody>
      <% products.forEach(function (p) { %>
        <tr>
          <td><%= p.id %></td>
          <td><a href="/products/<%= p.id %>"><%= p.title %></a></td>
          <td><%= p.seller_username %></td>
          <td><%= p.price %></td>
          <td><%= p.status %></td>
          <td>
            <form action="/admin/products/<%= p.id %>/status" method="POST" class="d-inline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn btn-sm btn-outline-warning"><%= p.status === 'blocked' ? '차단 해제' : '차단' %></button>
            </form>
            <form action="/admin/products/<%= p.id %>/delete" method="POST" class="d-inline" data-confirm="삭제하시겠습니까?">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn btn-sm btn-outline-danger">삭제</button>
            </form>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
  <script src="/js/confirm-forms.js"></script>
</div>
<%- include('../partials/foot') %>
