<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>신고 관리</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/nav') %>
<h1>신고 관리</h1>
<table border="1" cellpadding="4">
  <tr><th>ID</th><th>신고자</th><th>대상 종류</th><th>대상 ID</th><th>사유</th><th>상태</th><th>일시</th><th>액션</th></tr>
  <% reports.forEach(function (r) { %>
    <tr>
      <td><%= r.id %></td>
      <td><%= r.reporter_username %></td>
      <td><%= r.target_type === 'product' ? '상품' : '사용자' %></td>
      <td>
        <% if (r.target_type === 'product') { %>
          <a href="/products/<%= r.target_id %>"><%= r.target_id %></a>
        <% } else { %>
          <%= r.target_id %>
        <% } %>
      </td>
      <td><%= r.reason %></td>
      <td><%= r.resolved ? '처리완료' : '미처리' %></td>
      <td><%= r.created_at %></td>
      <td>
        <% if (!r.resolved) { %>
          <form action="/admin/reports/<%= r.id %>/resolve" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit">처리완료로 표시</button>
          </form>
        <% } %>
      </td>
    </tr>
  <% }) %>
</table>
</body>
</html>
