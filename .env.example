PORT=5000
NODE_ENV=development
SESSION_SECRET=change-this-to-a-long-random-string
DB_PATH=./data/app.sqlite

# ngrok 등 리버스 프록시 뒤에서 실행할 때만 true (X-Forwarded-For 스푸핑으로 rate limit
# 우회 가능해지므로, 실제로 프록시 뒤에 있을 때만 켤 것)
TRUST_PROXY=false

# npm run seed 실행시 사용되는 초기 관리자 계정 (기본값 없음, 반드시 직접 설정)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
